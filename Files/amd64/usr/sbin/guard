#!/usr/bin/env python3
# -*- coding: utf-8 -*-
import argparse
import sys

# Nota para desenvolvedores "RTP" significa
# aqui: "Real-Time Protection".

def main():
    parser = argparse.ArgumentParser(description="Ferramenta Guard CLI Simplificada")
    subparsers = parser.add_subparsers(dest="command", required=True)

    parser_scan = subparsers.add_parser("scan", help="Scan de um alvo")
    parser_scan.add_argument("target", metavar="STRING", help="String do alvo")
    parser_scan.add_argument("--nivel", type=int, required=True, help="Número inteiro do nível")

    parser_allow = subparsers.add_parser("allow", help="Permitir um alvo")
    parser_allow.add_argument("target", metavar="STRING", help="String do alvo")
    parser_allow.add_argument("--nivel", type=int, required=True, help="Número inteiro do nível")

    parser_block = subparsers.add_parser("block", help="Bloquear um alvo")
    parser_block.add_argument("target", metavar="STRING", help="String do alvo")
    parser_block.add_argument("--nivel", type=int, required=True, help="Número inteiro do nível")

    parser_rtp = subparsers.add_parser("rtp", help="Configurar modo RTP")
    parser_rtp.add_argument("value", choices=["true", "false"], help="Valor booleano para rtp")

    parser_firewall = subparsers.add_parser("firewall", help="Configurar firewall")
    parser_firewall.add_argument("value", choices=["true", "false"], help="Valor booleano para firewall")

    subparsers.add_parser("update", help="Atualizar guard")

    if len(sys.argv) == 1:
        parser.print_help()
        sys.exit(1)

    args = parser.parse_args()

    if args.command == "scan":
        print(f"Executando: guard scan {args.target} --nivel {args.nivel}")
    elif args.command == "allow":
        print(f"Executando: guard allow {args.target} --nivel {args.nivel}")
    elif args.command == "block":
        print(f"Executando: guard block {args.target} --nivel {args.nivel}")
    elif args.command == "rtp":
        print(f"Executando: guard rtp {args.value}")
    elif args.command == "firewall":
        print(f"Executando: guard firewall {args.value}")
    elif args.command == "update":
        print("Executando: guard update")


if __name__ == "__main__":
    main()
